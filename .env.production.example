# ═══════════════════════════════════════════════════════════════
# SIMEI Contador — Variáveis de Ambiente de PRODUÇÃO
# ═══════════════════════════════════════════════════════════════
# Este arquivo documenta todas as variáveis necessárias.
# Configure cada uma no painel do Render (API) e Vercel (frontend).
# NUNCA commite valores reais em arquivos de ambiente.
# ═══════════════════════════════════════════════════════════════

# ── API (configurar no Render > Environment) ─────────────────

NODE_ENV=production
PORT=3001

# MySQL — cole a "Service URI" do Aiven
# Formato: mysql://avnadmin:SENHA@HOST:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=mysql://avnadmin:SENHA@HOST:PORT/defaultdb?ssl-mode=REQUIRED

# JWT — use strings aleatórias longas (o Render pode gerar automaticamente)
JWT_SECRET=gere-uma-string-aleatoria-segura
JWT_REFRESH_SECRET=gere-outra-string-aleatoria-segura
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — URL do frontend no Vercel (sem barra no final)
ALLOWED_ORIGINS=https://seu-frontend.vercel.app

# GitHub Models — Agente IA
GITHUB_TOKEN=ghp_seu_token_aqui
GITHUB_MODEL=gpt-4o-mini

# ── Frontend (configurar no Vercel > Settings > Environment Variables) ──

# URL pública da API no Render (sem barra no final)
NEXT_PUBLIC_API_URL=https://seu-backend.onrender.com